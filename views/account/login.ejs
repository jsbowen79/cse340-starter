<h1>
    <%= title %>
</h1>

<%- messages() %>

    <form method="POST" action="/account/login" class="loginForm">
        <div>
            <label>Email:</label>
            <input type="email" name="email" required>
        </div>
        <div>
            <label>Password:</label>
            <input type="password" name="password" pattern="(?=.*?[A-Z])(?=.*?[a-z])(?=.*?[0-9])(?=.*?[#?!@$%^&*\-]).{12,}" required>
            <div class="pswdMsg">Password must include at least 12 characters and have at least 1 uppercase character, 1 number and 1 special
                character.</div>
            <button type="submit" id="accountBtn">Login</button>
        </div>


        <p>Need an account? <a href="/account/register"> Register Here. </a></p>
    </form>